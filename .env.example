# Optional. When absent, HackMatch AI uses deterministic fallback explanations.
OPENAI_API_KEY=
OPENAI_EXPLANATION_MODEL=gpt-5.2

# Optional remote persistence. When absent, HackMatch AI stores editable MVP data in localStorage.
# Use the Supabase project URL and public anon key. Never use the service role key in NEXT_PUBLIC_* env vars.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
